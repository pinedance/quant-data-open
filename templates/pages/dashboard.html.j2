<style>
  /* Override layout wrappers for dashboard grid flexibility */
  .table-wrapper {
    border: none !important;
    overflow-x: visible !important;
  }
  
  .dashboard-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    width: 100%;
  }

  /* Override parent container padding for mobile-first feel */
  @media (max-width: 640px) {
    body {
      padding: 0.5rem 0.25rem !important;
    }
    .container {
      padding: 0.5rem !important;
      border: none !important;
      background: transparent !important;
      box-shadow: none !important;
      margin-bottom: 0 !important;
    }
    h1 {
      font-size: 1.25rem !important;
      margin-bottom: 1rem !important;
      padding-left: 0.5rem !important;
    }
    .dash-card {
      padding: 0.75rem 0.5rem !important;
      border-radius: 8px !important;
    }
  }

  /* Cards */
  .dash-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.15), 0 2px 4px -1px rgba(0, 0, 0, 0.08);
  }

  .dash-card-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: #94a3b8;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid #334155;
    padding-bottom: 0.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Market Regime Section */
  .regime-body {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 0;
  }

  .regime-badge {
    font-size: 1.25rem;
    font-weight: 800;
    padding: 0.5rem 1.5rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    flex-shrink: 0;
    text-align: center;
  }

  .regime-bullish {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.35);
    box-shadow: 0 0 15px rgba(16, 185, 129, 0.15);
  }

  .regime-bearish {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.35);
    box-shadow: 0 0 15px rgba(239, 68, 68, 0.15);
  }

  .regime-stats {
    display: flex;
    flex-direction: column;
  }

  .regime-val {
    font-size: 2.2rem;
    font-weight: 800;
    color: #f8fafc;
    line-height: 1.1;
  }

  .regime-label {
    font-size: 0.75rem;
    color: #64748b;
    margin-top: 0.25rem;
    font-weight: 500;
  }

  /* Breakouts Section */
  .breakouts-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 480px) {
    .breakouts-split {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }

  .breakout-header {
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .breakout-up-header {
    color: #10b981;
  }

  .breakout-down-header {
    color: #ef4444;
  }

  .breakout-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    max-height: 180px;
    overflow-y: auto;
    padding-right: 0.25rem;
  }

  .breakout-item {
    background: #0f172a;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    border-left: 4px solid #64748b;
  }

  .breakout-item.up {
    border-left-color: #10b981;
  }

  .breakout-item.down {
    border-left-color: #ef4444;
  }

  .ticker-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: #f8fafc;
  }

  .ticker-desc {
    font-size: 0.7rem;
    color: #64748b;
    margin-top: 0.1rem;
  }

  .no-breakouts {
    color: #475569;
    font-size: 0.8rem;
    padding: 1rem;
    text-align: center;
    background: #0f172a;
    border-radius: 8px;
    border: 1px dashed #334155;
  }

  /* Region Badge */
  .region-badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .region-us {
    background: rgba(139, 92, 246, 0.15);
    color: #8b5cf6;
    border: 1px solid rgba(139, 92, 246, 0.25);
  }

  .region-kr {
    background: rgba(59, 130, 246, 0.15);
    color: #3b82f6;
    border: 1px solid rgba(59, 130, 246, 0.25);
  }

  /* Valuation Table */
  .toggle-section {
    border-top: 1px solid #334155;
    margin-top: 1rem;
    padding-top: 0.75rem;
  }

  .toggle-summary {
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 700;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    user-select: none;
  }

  .toggle-summary::-webkit-details-marker {
    display: none;
  }

  .toggle-summary::after {
    content: "▶";
    font-size: 0.6rem;
    color: #64748b;
    transition: transform 0.2s ease;
  }

  details[open] .toggle-summary::after {
    content: "▼";
  }

  .val-table-wrap {
    overflow-x: auto;
    margin-top: 0.75rem;
    border-radius: 8px;
    border: 1px solid #334155;
    background: #0f172a;
  }

  .val-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .val-table th {
    background-color: #0f172a;
    color: #64748b;
    padding: 0.6rem 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    border-bottom: 2px solid #334155;
  }

  .val-table td {
    padding: 0.6rem 0.8rem;
    border-bottom: 1px solid #1e293b;
    color: #cbd5e1;
  }

  .val-table tbody tr:hover {
    background-color: rgba(51, 65, 85, 0.2);
  }

  /* Table Highlights */
  .row-hot {
    background-color: rgba(239, 68, 68, 0.08) !important;
    color: #f87171 !important;
  }

  .row-hot td {
    color: #f87171 !important;
  }

  .row-hot .ticker-name-cell, .row-hot .ticker-symbol-cell {
    color: #fca5a5 !important;
    font-weight: 700 !important;
  }

  .row-cold {
    background-color: rgba(59, 130, 246, 0.08) !important;
    color: #60a5fa !important;
  }

  .row-cold td {
    color: #60a5fa !important;
  }

  .row-cold .ticker-name-cell, .row-cold .ticker-symbol-cell {
    color: #93c5fd !important;
    font-weight: 700 !important;
  }

  .ticker-symbol-cell {
    font-weight: 600;
  }

  .ticker-name-cell {
    color: #94a3b8;
  }

  .status-badge {
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.7rem;
  }

  .status-overheated {
    background-color: rgba(239, 68, 68, 0.15);
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.25);
  }

  .status-depressed {
    background-color: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.25);
  }

  .status-normal {
    color: #64748b;
  }

  .text-green {
    color: #10b981 !important;
  }

  .text-red {
    color: #ef4444 !important;
  }

  /* Data Quality */
  .dq-card {
    padding: 0.75rem 1rem !important;
  }

  .dq-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .status-warning {
    background-color: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.25);
  }

  .status-healthy {
    background-color: rgba(16, 185, 129, 0.15);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.25);
  }

  .dq-content {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid #334155;
  }

  .dq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dq-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #0f172a;
    padding: 0.6rem 0.8rem;
    border-radius: 6px;
    border: 1px solid rgba(239, 68, 68, 0.15);
  }

  .dq-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .dq-col {
    font-weight: 700;
    color: #ef4444;
    font-size: 0.85rem;
  }

  .dq-nan {
    font-size: 0.75rem;
    color: #94a3b8;
  }

  .dq-range {
    font-size: 0.75rem;
    color: #64748b;
    font-family: monospace;
  }

  .dq-clean {
    text-align: center;
    color: #10b981;
    font-size: 0.85rem;
    padding: 1rem 0;
    background: #0f172a;
    border-radius: 6px;
  }

  /* Scrollbars */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #0f172a;
  }
  ::-webkit-scrollbar-thumb {
    background: #334155;
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #475569;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>

<div class="dashboard-container">
  <!-- ① Market Regime -->
  <div class="dash-card">
    <div class="dash-card-title">
      <span>Market Regime</span>
      <span class="region-badge region-us">TIP</span>
    </div>
    <div class="regime-body">
      {% if data.market_regime.status == 'Bullish' %}
        <div class="regime-badge regime-bullish">BULLISH</div>
      {% else %}
        <div class="regime-badge regime-bearish">BEARISH</div>
      {% endif %}
      <div class="regime-stats">
        <span class="regime-val">{{ '+' if data.market_regime.tip_momentum > 0 else '' }}{{ "%.2f"|format(data.market_regime.tip_momentum) }}%</span>
        <span class="regime-label">TIP Average Momentum (1, 3, 6, 12m)</span>
      </div>
    </div>
  </div>

  <!-- ② Trend Breakouts -->
  <div class="dash-card">
    <div class="dash-card-title">
      <span>Trend Breakouts</span>
      <span class="region-badge" style="background:#334155;color:#94a3b8;">EMA200 vs EMA5</span>
    </div>
    <div class="breakouts-split">
      <!-- Upward Breakouts -->
      <div>
        <div class="breakout-header breakout-up-header">상향 돌파 (Cross Above)</div>
        <div class="breakout-list">
          {% for item in data.trend_breakouts.up_breakouts %}
            <div class="breakout-item up">
              {% if region == 'KR' %}
                <div class="ticker-name">{{ item.name }}</div>
                <div class="ticker-desc">{{ item.ticker }}</div>
              {% else %}
                <div class="ticker-name">{{ item.ticker }}</div>
                <div class="ticker-desc">{{ item.name }}</div>
              {% endif %}
            </div>
          {% else %}
            <div class="no-breakouts">상향 돌파 종목 없음</div>
          {% endfor %}
        </div>
      </div>
      <!-- Downward Breakouts -->
      <div>
        <div class="breakout-header breakout-down-header">하향 돌파 (Cross Below)</div>
        <div class="breakout-list">
          {% for item in data.trend_breakouts.down_breakouts %}
            <div class="breakout-item down">
              {% if region == 'KR' %}
                <div class="ticker-name">{{ item.name }}</div>
                <div class="ticker-desc">{{ item.ticker }}</div>
              {% else %}
                <div class="ticker-name">{{ item.ticker }}</div>
                <div class="ticker-desc">{{ item.name }}</div>
              {% endif %}
            </div>
          {% else %}
            <div class="no-breakouts">하향 돌파 종목 없음</div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <!-- ②-2 RSI Landscape -->
  <div class="dash-card">
    <div class="dash-card-title">
      <span>RSI Landscape</span>
      <span style="font-size:0.65rem;color:#475569;font-weight:normal;">x: RSI Diff (RSI - Signal) &nbsp;·&nbsp; y: RSI</span>
    </div>

    <!-- ECharts.js scatter plot element -->
    <div id="rsi-chart" style="width: 100%; height: 600px; margin-top: 1rem;"></div>

    <script>
    (function() {
      var chartData = [
        {% for item in data.rsi_extremes %}
        {
          value: [{{ item.rsi_diff | default(0.0) }}, {{ item.rsi | default(50.0) }}],
          ticker: {{ item.ticker | tojson }},
          name: {{ item.name | tojson }},
          rsi: {{ item.rsi | default(50.0) }},
          rsi_signal: {{ item.rsi_signal | default(50.0) }},
          rsi_diff: {{ item.rsi_diff | default(0.0) }}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ];

      function symAxisBound(v, pad) {
        return -(Math.max(Math.abs(v.min), Math.abs(v.max)) + pad);
      }

      var chart = echarts.init(document.getElementById('rsi-chart'));
      chart.setOption({
        backgroundColor: 'transparent',
        grid: { left: 48, right: 16, top: 35, bottom: 48 },
        toolbox: {
          show: true,
          top: 0,
          right: 10,
          feature: {
            restore: {
              show: true,
              title: 'Reset'
            }
          },
          iconStyle: {
            borderColor: '#94a3b8'
          },
          emphasis: {
            iconStyle: {
              borderColor: '#ffffff'
            }
          }
        },
        dataZoom: [
          { type: 'inside', xAxisIndex: 0, filterMode: 'none' },
          { type: 'inside', yAxisIndex: 0, filterMode: 'none' }
        ],
        xAxis: {
          type: 'value',
          min: function(v) { return  symAxisBound(v, 5); },
          max: function(v) { return -symAxisBound(v, 5); },
          name: 'RSI Diff (RSI - Signal)',
          nameLocation: 'middle',
          nameGap: 28,
          nameTextStyle: { color: '#94a3b8', fontSize: 11, fontWeight: 600 },
          axisLine: { lineStyle: { color: '#475569', width: 1.5 } },
          splitLine: { lineStyle: { color: '#334155', type: 'dashed' } },
          axisLabel: { color: '#cbd5e1', fontSize: 10 }
        },
        yAxis: {
          type: 'value',
          min: 0,
          max: 100,
          name: 'RSI',
          nameLocation: 'middle',
          nameGap: 32,
          nameTextStyle: { color: '#94a3b8', fontSize: 11, fontWeight: 600 },
          axisLine: { lineStyle: { color: '#475569', width: 1.5 } },
          splitLine: { lineStyle: { color: '#334155', type: 'dashed' } },
          axisLabel: { color: '#cbd5e1', fontSize: 10 }
        },
        tooltip: {
          trigger: 'item',
          backgroundColor: 'rgba(30, 41, 59, 0.95)',
          borderColor: '#475569',
          borderWidth: 1,
          padding: [10, 14],
          textStyle: { color: '#f1f5f9', fontSize: 12 },
          formatter: function(params) {
            var d = params.data;
            var header = {{ region | tojson }} === 'KR' ? (d.name + ' <span style="font-size:10px;color:#94a3b8;">' + d.ticker + '</span>') : (d.ticker + ' <span style="font-size:10px;color:#94a3b8;">' + d.name + '</span>');
            return '<div style="font-weight:700;margin-bottom:6px;border-bottom:1px solid #334155;padding-bottom:4px;">' + header + '</div>'
              + '<div style="display:flex;justify-content:space-between;gap:15px;margin-bottom:2px;">'
              + '<span style="color:#94a3b8;">RSI:</span>'
              + '<span style="font-weight:600;color:' + (d.rsi > 70 ? '#f87171' : (d.rsi < 30 ? '#60a5fa' : '#cbd5e1')) + '">' + d.rsi.toFixed(2) + '</span>'
              + '</div>'
              + '<div style="display:flex;justify-content:space-between;gap:15px;margin-bottom:2px;">'
              + '<span style="color:#94a3b8;">RSI Signal:</span>'
              + '<span style="font-weight:600;color:#cbd5e1">' + d.rsi_signal.toFixed(2) + '</span>'
              + '</div>'
              + '<div style="display:flex;justify-content:space-between;gap:15px;">'
              + '<span style="color:#94a3b8;">RSI Diff:</span>'
              + '<span style="font-weight:600;color:' + (d.rsi_diff > 0 ? '#10b981' : (d.rsi_diff < 0 ? '#ef4444' : '#cbd5e1')) + '">' + d.rsi_diff.toFixed(2) + '</span>'
              + '</div>';
          }
        },
        series: [{
          type: 'scatter',
          data: chartData,
          symbolSize: 10,
          itemStyle: {
            color: function(params) {
              var r = params.data.rsi;
              if (r > 70) return '#f87171'; // soft red
              if (r < 30) return '#60a5fa'; // soft blue
              return '#6366f1'; // indigo
            },
            shadowBlur: 8,
            shadowColor: 'rgba(99, 102, 241, 0.4)',
            opacity: 0.95
          },
          label: {
            show: true,
            formatter: function(params) {
              return params.data.ticker;
            },
            position: 'top',
            fontSize: 9,
            color: '#cbd5e1',
            fontWeight: 600,
            distance: 5
          },
          labelLayout: {
            hideOverlap: true
          },
          emphasis: {
            scale: true,
            itemStyle: {
              shadowBlur: 15,
              shadowColor: 'rgba(255, 255, 255, 0.6)',
              opacity: 1
            },
            label: {
              color: '#ffffff',
              fontSize: 10,
              fontWeight: 700
            }
          },
          markLine: {
            silent: true,
            symbol: 'none',
            label: { show: false },
            data: [
              { xAxis: 0, lineStyle: { type: 'solid', color: '#64748b', width: 1.5 } },
              { yAxis: 30, lineStyle: { type: 'dashed', color: '#475569', width: 1 } },
              { yAxis: 70, lineStyle: { type: 'dashed', color: '#475569', width: 1 } }
            ]
          }
        }]
      });

      chart.getZr().on('dblclick', function() {
        chart.dispatchAction({
          type: 'restore'
        });
      });

      window.addEventListener('resize', function() { chart.resize(); });
    })();
    </script>

    <!-- Toggle: RSI Table -->
    <details class="toggle-section" {% if not data.rsi_extremes %}style="display:none;"{% endif %}>
      <summary class="toggle-summary">RSI Table</summary>
      <div class="val-table-wrap">
        <table class="val-table">
          <thead>
            <tr>
              {% if region == 'KR' %}
                <th>Name</th>
                <th>Ticker</th>
              {% else %}
                <th>Ticker</th>
                <th>Name</th>
              {% endif %}
              <th>RSI</th>
              <th>RSI Signal</th>
              <th>RSI Diff</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {% for item in data.rsi_extremes %}
              {% set is_hot  = item.rsi > 70 %}
              {% set is_cold = item.rsi < 30 %}
              <tr class="{% if is_hot %}row-hot{% elif is_cold %}row-cold{% endif %}">
                {% if region == 'KR' %}
                  <td class="ticker-name-cell">{{ item.name }}</td>
                  <td class="ticker-symbol-cell">{{ item.ticker }}</td>
                {% else %}
                  <td class="ticker-symbol-cell">{{ item.ticker }}</td>
                  <td class="ticker-name-cell">{{ item.name }}</td>
                {% endif %}
                <td style="font-weight:700;">{{ "%.2f"|format(item.rsi) }}</td>
                <td>{{ "%.2f"|format(item.rsi_signal) }}</td>
                <td class="{{ 'text-green' if item.rsi_diff > 0 else ('text-red' if item.rsi_diff < 0 else '') }}" style="font-weight:600;">
                  {{ '+' if item.rsi_diff > 0 else '' }}{{ "%.2f"|format(item.rsi_diff) }}
                </td>
                <td>
                  {% if is_hot %}
                    <span class="status-badge status-overheated">{% if region == 'KR' %}과열{% else %}Overheated{% endif %}</span>
                  {% elif is_cold %}
                    <span class="status-badge status-depressed">{% if region == 'KR' %}침체{% else %}Depressed{% endif %}</span>
                  {% else %}
                    <span class="status-normal">{% if region == 'KR' %}정상{% else %}Normal{% endif %}</span>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </details>
  </div>

  <!-- ③ Market Landscape -->
  <div class="dash-card">
    <div class="dash-card-title">
      <span>Market Landscape</span>
      <span style="font-size:0.65rem;color:#475569;font-weight:normal;">x: MACD Z &nbsp;·&nbsp; y: T-Sigma</span>
    </div>

    <!-- ECharts.js scatter plot element -->
    <div id="landscape-chart" style="width: 100%; height: 600px; margin-top: 1rem;"></div>

    <script>
    (function() {
      var chartData = [
        {% for item in data.valuation_extremes %}
        {
          value: [{{ item.macd_z | default(0.0) }}, {{ item.t_sigma | default(0.0) }}],
          ticker: {{ item.ticker | tojson }},
          name: {{ item.name | tojson }},
          t_sigma: {{ item.t_sigma | default(0.0) }},
          macd_z: {{ item.macd_z | default(0.0) }},
          macd_hist: {{ item.macd_hist | default(0.0) }}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ];

      function symAxisBound(v, pad) {
        return -(Math.max(Math.abs(v.min), Math.abs(v.max)) + pad);
      }

      var chart = echarts.init(document.getElementById('landscape-chart'));
      chart.setOption({
        backgroundColor: 'transparent',
        grid: { left: 48, right: 16, top: 35, bottom: 48 },
        toolbox: {
          show: true,
          top: 0,
          right: 10,
          feature: {
            restore: {
              show: true,
              title: 'Reset'
            }
          },
          iconStyle: {
            borderColor: '#94a3b8'
          },
          emphasis: {
            iconStyle: {
              borderColor: '#ffffff'
            }
          }
        },
        dataZoom: [
          { type: 'inside', xAxisIndex: 0, filterMode: 'none' },
          { type: 'inside', yAxisIndex: 0, filterMode: 'none' }
        ],
        xAxis: {
          type: 'value',
          min: function(v) { return  symAxisBound(v, 0.5); },
          max: function(v) { return -symAxisBound(v, 0.5); },
          name: 'MACD Z',
          nameLocation: 'middle',
          nameGap: 28,
          nameTextStyle: { color: '#94a3b8', fontSize: 11, fontWeight: 600 },
          axisLine: { lineStyle: { color: '#475569', width: 1.5 } },
          splitLine: { lineStyle: { color: '#334155', type: 'dashed' } },
          axisLabel: { color: '#cbd5e1', fontSize: 10 }
        },
        yAxis: {
          type: 'value',
          min: function(v) { return  symAxisBound(v, 0.5); },
          max: function(v) { return -symAxisBound(v, 0.5); },
          name: 'T-Sigma',
          nameLocation: 'middle',
          nameGap: 32,
          nameTextStyle: { color: '#94a3b8', fontSize: 11, fontWeight: 600 },
          axisLine: { lineStyle: { color: '#475569', width: 1.5 } },
          splitLine: { lineStyle: { color: '#334155', type: 'dashed' } },
          axisLabel: { color: '#cbd5e1', fontSize: 10 }
        },
        tooltip: {
          trigger: 'item',
          backgroundColor: 'rgba(30, 41, 59, 0.95)',
          borderColor: '#475569',
          borderWidth: 1,
          padding: [10, 14],
          textStyle: { color: '#f1f5f9', fontSize: 12 },
          formatter: function(params) {
            var d = params.data;
            var header = {{ region | tojson }} === 'KR' ? (d.name + ' <span style="font-size:10px;color:#94a3b8;">' + d.ticker + '</span>') : (d.ticker + ' <span style="font-size:10px;color:#94a3b8;">' + d.name + '</span>');
            return '<div style="font-weight:700;margin-bottom:6px;border-bottom:1px solid #334155;padding-bottom:4px;">' + header + '</div>'
              + '<div style="display:flex;justify-content:space-between;gap:15px;margin-bottom:2px;">'
              + '<span style="color:#94a3b8;">T-Sigma:</span>'
              + '<span style="font-weight:600;color:' + (d.t_sigma > 2.5 ? '#f87171' : (d.t_sigma < -2.5 ? '#60a5fa' : '#cbd5e1')) + '">' + d.t_sigma.toFixed(2) + '</span>'
              + '</div>'
              + '<div style="display:flex;justify-content:space-between;gap:15px;margin-bottom:2px;">'
              + '<span style="color:#94a3b8;">MACD Z-score:</span>'
              + '<span style="font-weight:600;color:' + (d.macd_z > 0 ? '#10b981' : (d.macd_z < 0 ? '#ef4444' : '#cbd5e1')) + '">' + d.macd_z.toFixed(2) + '</span>'
              + '</div>'
              + '<div style="display:flex;justify-content:space-between;gap:15px;">'
              + '<span style="color:#94a3b8;">MACD Hist:</span>'
              + '<span style="font-weight:600;color:' + (d.macd_hist > 0 ? '#10b981' : (d.macd_hist < 0 ? '#ef4444' : '#cbd5e1')) + '">' + d.macd_hist.toFixed(2) + '</span>'
              + '</div>';
          }
        },
        series: [{
          type: 'scatter',
          data: chartData,
          symbolSize: 10,
          itemStyle: {
            color: function(params) {
              var t = params.data.t_sigma;
              if (t > 2.5) return '#f87171'; // soft red
              if (t < -2.5) return '#60a5fa'; // soft blue
              return '#6366f1'; // indigo
            },
            shadowBlur: 8,
            shadowColor: 'rgba(99, 102, 241, 0.4)',
            opacity: 0.95
          },
          label: {
            show: true,
            formatter: function(params) {
              return params.data.ticker;
            },
            position: 'top',
            fontSize: 9,
            color: '#cbd5e1',
            fontWeight: 600,
            distance: 5
          },
          labelLayout: {
            hideOverlap: true
          },
          emphasis: {
            scale: true,
            itemStyle: {
              shadowBlur: 15,
              shadowColor: 'rgba(255, 255, 255, 0.6)',
              opacity: 1
            },
            label: {
              color: '#ffffff',
              fontSize: 10,
              fontWeight: 700
            }
          },
          markLine: {
            silent: true,
            symbol: 'none',
            label: { show: false },
            data: [
              { xAxis: 0, lineStyle: { type: 'solid', color: '#64748b', width: 1.5 } },
              { yAxis: 0, lineStyle: { type: 'solid', color: '#64748b', width: 1.5 } },
              { xAxis: 2, lineStyle: { type: 'dashed', color: '#475569', width: 1 } },
              { xAxis: -2, lineStyle: { type: 'dashed', color: '#475569', width: 1 } },
              { yAxis: 2.5, lineStyle: { type: 'dashed', color: '#475569', width: 1 } },
              { yAxis: -2.5, lineStyle: { type: 'dashed', color: '#475569', width: 1 } }
            ]
          }
        }]
      });

      // Double-click to restore zoom
      chart.getZr().on('dblclick', function() {
        chart.dispatchAction({
          type: 'restore'
        });
      });

      window.addEventListener('resize', function() { chart.resize(); });
    })();
    </script>

    <!-- Toggle: Valuation Table -->
    <details class="toggle-section" {% if not data.valuation_extremes %}style="display:none;"{% endif %}>
      <summary class="toggle-summary">Valuation Table</summary>
      <div class="val-table-wrap">
        <table class="val-table">
          <thead>
            <tr>
              {% if region == 'KR' %}
                <th>Name</th>
                <th>Ticker</th>
              {% else %}
                <th>Ticker</th>
                <th>Name</th>
              {% endif %}
              <th>T-Sigma (Z)</th>
              <th>Simple Z</th>
              <th>MACD Hist</th>
              <th>MACD Z</th>
              <th>Opt DF</th>
              <th>Avg Mom</th>
              <th>EMA5 / EMA200</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {% for item in data.valuation_extremes %}
              {% set is_hot  = item.t_sigma >  2.5 %}
              {% set is_cold = item.t_sigma < -2.5 %}
              <tr class="{% if is_hot %}row-hot{% elif is_cold %}row-cold{% endif %}">
                {% if region == 'KR' %}
                  <td class="ticker-name-cell">{{ item.name }}</td>
                  <td class="ticker-symbol-cell">{{ item.ticker }}</td>
                {% else %}
                  <td class="ticker-symbol-cell">{{ item.ticker }}</td>
                  <td class="ticker-name-cell">{{ item.name }}</td>
                {% endif %}
                <td class="val-t-sigma" style="font-weight:700;">
                  {{ '+' if item.t_sigma > 0 else '' }}{{ "%.2f"|format(item.t_sigma) }}
                </td>
                <td class="val-simple-z">{{ '+' if item.raw_z > 0 else '' }}{{ "%.2f"|format(item.raw_z) }}</td>
                <td class="val-macd-hist">{{ '+' if item.macd_hist > 0 else '' }}{{ "%.2f"|format(item.macd_hist) }}</td>
                <td class="val-macd-z">{{ '+' if item.macd_z > 0 else '' }}{{ "%.2f"|format(item.macd_z) }}</td>
                <td class="val-df">{{ "%.2f"|format(item.df) if item.df is number else item.df }}</td>
                <td class="val-avg-mom {{ 'text-green' if item.avg_mom > 0 else ('text-red' if item.avg_mom < 0 else '') }}" style="font-weight:600;">
                  {{ '+' if item.avg_mom > 0 else '' }}{{ "%.2f"|format(item.avg_mom) }}%
                </td>
                <td class="val-ema">{{ "%.2f"|format(item.ema005) }} / {{ "%.2f"|format(item.ema200) }}</td>
                <td>
                  {% if is_hot %}
                    <span class="status-badge status-overheated">{% if region == 'KR' %}과열{% else %}Overheated{% endif %}</span>
                  {% elif is_cold %}
                    <span class="status-badge status-depressed">{% if region == 'KR' %}침체{% else %}Depressed{% endif %}</span>
                  {% else %}
                    <span class="status-normal">{% if region == 'KR' %}정상{% else %}Normal{% endif %}</span>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </details>
  </div>

  <!-- ④ Data Quality Status -->
  <details class="dash-card dq-card">
    <summary class="toggle-summary dq-summary">
      <span>Data Quality Status</span>
      {% if data.data_quality_status %}
        <span class="status-badge status-warning">Warning</span>
      {% else %}
        <span class="status-badge status-healthy">Healthy</span>
      {% endif %}
    </summary>
    <div class="dq-content">
      {% if data.data_quality_status %}
        <div class="dq-list">
          {% for item in data.data_quality_status %}
            <div class="dq-item">
              <div class="dq-meta">
                <span class="dq-col">{{ item.ticker or item.column }}<span style="font-size: 0.75rem; color: #64748b; font-weight: normal; margin-left: 0.25rem;">({{ item.name }})</span></span>
                <span class="dq-nan">NaN count: <strong>{{ item.count }}</strong></span>
              </div>
              <span class="dq-range">{{ item.range }}</span>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="dq-clean">
          ✓ 모든 데이터의 결측치(NaN) 검증을 통과했습니다. (All data quality checks passed)
        </div>
      {% endif %}
    </div>
  </details>

  <div style="text-align: right; font-size: 0.7rem; color: #475569;">
    Last updated: {{ data.last_updated }}
  </div>
</div>
